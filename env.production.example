# Copy into Vercel → alyson-client → Settings → Environment Variables (Production)
# https://alyson-client.vercel.app

RESEND_API_KEY=
RESEND_FROM_EMAIL=Alyson HR <reports@cintara.ai>
DAILY_REPORT_ENABLED=true
DAILY_REPORT_RECIPIENTS=alysonclient@cintara.ai,thirumalai@cintara.ai
DAILY_REPORT_CRON_SECRET=
CRON_SECRET=
# Optional: separate code for Reports → Daily email → Send now (defaults to CRON_SECRET)
DAILY_REPORT_UI_SEND_CODE=
DAILY_REPORT_INCLUDE_HOURLY=false
DAILY_REPORT_INCLUDE_SCORING=true
DAILY_REPORT_INCLUDE_WORKSPACE=true
DAILY_REPORT_INCLUDE_TIME_DOCTOR=true
DAILY_REPORT_HOURS_BACK=24

# Time Doctor API (auto-refresh when refresh + OAuth client are set)
API_BASE_URL=https://webapi.timedoctor.com/v1.1
API_ACCESS_TOKEN=
API_ACCESS_TOKEN_EXPIRES_AT=
API_REFRESH_TOKEN=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
# Optional override; default is read from Time Doctor company_time_zone (Revcloud = US Central)
TIME_DOCTOR_TIMEZONE=America/Chicago

# Unified meeting bot schedule state (same bucket as Notetaker — survives Vercel restarts)
# UNIFIED_SCHEDULED_STATE_SOURCE=auto

# Notetaker transcript cron — dumps all transcripts to S3 every 5 min (vercel.json)
NOTETAKER_TRANSCRIPT_CRON_ENABLED=true
NOTETAKER_TRANSCRIPT_CRON_SECRET=
NOTETAKER_AUTO_PERSIST_S3=true
# false = rely on cron only; true = also sync when someone opens Notetaker UI
NOTETAKER_SESSIONS_BACKGROUND_SYNC=false
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
ALYSON_NOTETAKER_BASE_URL=
VITE_ALYSON_NOTETAKER_BASE_URL=
# Recall transcript webhooks must hit the Notetaker service (not this Vercel app)
PUBLIC_WEBHOOK_BASE_URL=https://api-uic1.onrender.com
RECALL_TRANSCRIPT_WEBHOOK_URL=https://api-uic1.onrender.com/webhooks/recall
TRANSCRIPT_LANGUAGE=en

# Recall Calendar V2 — auto-schedule bots from Google Calendar webhooks
RECALL_API_KEY=
RECALL_BASE_URL=https://ap-northeast-1.recall.ai
RECALL_CALENDAR_ID=
RECALL_CALENDAR_OAUTH_REDIRECT_URI=https://alyson-client.vercel.app/api/recall/calendar/callback
RECALL_CALENDAR_WEBHOOK_SECRET=
# Option B (recommended, Dec 2025+ accounts): workspace secret — same var verifies calendar + transcript webhooks
RECALL_VERIFICATION_SECRET=
RECALL_CALENDAR_AUTO_SCHEDULE_EMAILS=alysonclient@cintara.ai,mohita@cintara.ai,thirumalai@cintara.ai
ALYSON_APP_BASE_URL=https://alyson-client.vercel.app
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Bonus & shares ledger (same bucket as onboarding — s3://alyson-hr-orgchart/bonus/)
# ALYSON_HR_BONUS_S3_KEY=bonus/data.json
# ALYSON_HR_BONUS_LOG_S3_KEY=bonus/operations.log.jsonl

# Plus all Google DWD + Clerk + Supabase vars from your local .env
